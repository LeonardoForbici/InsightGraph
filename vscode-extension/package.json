{
  "name": "insightgraph",
  "displayName": "InsightGraph",
  "description": "Code dependency graph insights directly in VS Code",
  "version": "0.1.0",
  "publisher": "insightgraph",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "insightgraph.analyzeImpact",
        "title": "InsightGraph: Analisar Impacto"
      },
      {
        "command": "insightgraph.scanProject",
        "title": "InsightGraph: Escanear Projeto"
      }
    ],
    "configuration": {
      "title": "InsightGraph",
      "properties": {
        "insightgraph.serverUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL do servidor InsightGraph backend"
        },
        "insightgraph.autoAnalyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Analisar automaticamente ao salvar arquivos"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
