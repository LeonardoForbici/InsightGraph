# Code Intelligence OS - Environment Configuration

# ──────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ──────────────────────────────────────────────
# Ollama AI Configuration
# ──────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Tier 1: Fast Scan (Ultra fast, doesn't freeze PC during scan)
OLLAMA_FAST_MODEL=qwen2.5-coder:1.5b

# Tier 2: Chat & Q&A (Better conversation and business understanding)
OLLAMA_CHAT_MODEL=qwen3.5:4b

# Tier 3: Complex Analysis (Maximum intelligence, but slow)
OLLAMA_COMPLEX_MODEL=qwen3-coder-next:q4_K_M

# Embedding model for RAG
OLLAMA_EMBED_MODEL=nomic-embed-text

# GPU Configuration
OLLAMA_FORCE_GPU=0
OLLAMA_NUM_GPU=999

# ──────────────────────────────────────────────
# Storage Configuration
# ──────────────────────────────────────────────
STATE_DB_FILE=insightgraph_state.db
RAG_INDEX_FILE=rag_index.json
RAG_STORE_FILE=rag_store.db
QUALITY_HISTORY_FILE=quality_gate_history.json
QUALITY_HISTORY_LIMIT=20

# ──────────────────────────────────────────────
# Report Configuration
# ──────────────────────────────────────────────
REPORT_PROJECT_NAME=InsightGraph
REPORT_LOGO_TEXT=InsightGraph
REPORTS_OUTPUT_DIR=./reports

# ──────────────────────────────────────────────
# Multi-Tenant Configuration
# ──────────────────────────────────────────────
TENANT_ID=
ADMIN_TOKEN=

# ──────────────────────────────────────────────
# Feature Flags - Backend
# ──────────────────────────────────────────────

# Enable Server-Sent Events for real-time updates
ENABLE_SSE=true

# Enable Git integration for temporal navigation
ENABLE_GIT=true

# Enable AI-powered natural language queries
ENABLE_AI_QUERY=true

# Enable Timeline 4D for commit history navigation
ENABLE_TIMELINE=true

# Enable Investigation Mode for guided analysis
ENABLE_INVESTIGATION=true

# Enable performance monitoring and metrics
ENABLE_PERFORMANCE_MONITORING=true

# Enable impact calculation caching
ENABLE_IMPACT_CACHE=true

# Enable Neo4j connection pooling (experimental)
ENABLE_CONNECTION_POOL=false

# ──────────────────────────────────────────────
# Feature Flags - Frontend
# ──────────────────────────────────────────────

# Enable SSE connection for real-time updates
REACT_APP_ENABLE_SSE=true

# Enable Timeline 4D component
REACT_APP_ENABLE_TIMELINE=true

# Enable AI Query Engine component
REACT_APP_ENABLE_AI_QUERY=true

# Enable Investigation Mode component
REACT_APP_ENABLE_INVESTIGATION=true

# ──────────────────────────────────────────────
# Performance Tuning
# ──────────────────────────────────────────────

# Impact cache settings
IMPACT_CACHE_TTL=300
IMPACT_CACHE_MAX_SIZE=1000

# SSE settings
SSE_HEARTBEAT_INTERVAL=30
SSE_CLIENT_TIMEOUT=50

# Git settings
GIT_SHALLOW_CLONE=true
GIT_COMMIT_CACHE_SIZE=50

# Performance monitoring
PERF_SLOW_THRESHOLD_MS=1000
